# MariaDB 11 — Docker-friendly defaults (not host-RAM autoscale).
# Tuned for modest RAM while staying usable for higher traffic than a tiny lab box.
# "2M monthly visitors" is an app metric; DB load depends on queries, cache (e.g. Redis),
# and data size — raise innodb_buffer_pool_size on a dedicated DB server if needed.

[mariadbd]
# Single small pool: keep instances = 1 (required when pool < ~1G on older docs; still fine here).
innodb_buffer_pool_size = 128M
innodb_buffer_pool_instances = 1
innodb_log_buffer_size = 256K
# Local / staging: faster commits, slightly higher crash window. Production: use 1 instead.
innodb_flush_log_at_trx_commit = 2

max_connections = 50
table_open_cache = 200
# Keep below max_connections; large thread_cache wastes RAM for little gain.
thread_cache_size = 20

sort_buffer_size = 512K
join_buffer_size = 256K
read_buffer_size = 128K
read_rnd_buffer_size = 128K

tmp_table_size = 16M
max_heap_table_size = 16M

# Dev/staging: saves RAM. Production troubleshooting: consider ON.
performance_schema = OFF
