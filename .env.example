# --- MariaDB ---
DB_ROOT_PASSWORD=rootpass
DB_NAME=diu_tracker
DB_USER=diu
DB_PASSWORD=diupass

# --- Backend ---
# Public URL the browser uses to reach the app (used to build email links).
FRONTEND_URL=http://localhost:4444

# --- Email verification ---
# Turn on to require CRs to verify their email during signup.
EMAIL_VERIFICATION_ENABLED=false

# --- Gmail SMTP (needed only when EMAIL_VERIFICATION_ENABLED=true) ---
# Use a Gmail "App Password" (Google Account → Security → App passwords),
# not your normal password. 2-Step Verification must be on.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASSWORD=your-16-char-app-password
# Optional. Defaults to SMTP_USER if left blank.
SMTP_FROM=

# --- Firebase Cloud Messaging (push — records, notices, deadlines) ---
# 1) Firebase Console → Service accounts → Generate new private key → save as firebase.json
# 2) Encode (PowerShell): [Convert]::ToBase64String([IO.File]::ReadAllBytes("firebase.json"))
#    Linux/macOS: base64 -w0 firebase.json   (or: base64 -i firebase.json | tr -d '\n')
# 3) Paste one line below (no quotes needed unless your host requires them)
FCM_ENABLED=true
FCM_TOKEN_BASE64=
