# Copy to .env and adjust before running `docker compose up -d --build`.
# Browser → Caddy (frontend, port 4444) → backend (internal only, not published).

# --- MariaDB ---
DB_ROOT_PASSWORD=rootpass
DB_NAME=diu_tracker
DB_USER=diu
DB_PASSWORD=diupass

# --- Backend ---
# Public URL the browser uses to reach the app (used to build email links).
FRONTEND_URL=http://localhost:4444

# --- Email verification ---
# Turn on to require CRs to verify their email during signup.
EMAIL_VERIFICATION_ENABLED=false

# --- Gmail SMTP (needed only when EMAIL_VERIFICATION_ENABLED=true) ---
# Use a Gmail "App Password" (Google Account → Security → App passwords),
# not your normal password. 2-Step Verification must be on.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-address@gmail.com
SMTP_PASSWORD=your-16-char-app-password
# Optional. Defaults to SMTP_USER if left blank.
SMTP_FROM=
