# Caddy serves the built SPA and reverse-proxies API + media to the backend,
# so the backend container never needs a published port.
:80 {
	encode gzip zstd

	root * /srv

	# API calls are namespaced under /api (the /api prefix is stripped before proxying).
	handle_path /api/* {
		reverse_proxy backend:8000
	}

	# Backend-served media (avatars / teacher photos) are same-origin in the app.
	handle /static/* {
		reverse_proxy backend:8000
	}

	# Long-cache hashed build assets.
	@assets path /assets/*
	header @assets Cache-Control "public, max-age=31536000, immutable"

	# SPA fallback for client-side routes.
	handle {
		try_files {path} /index.html
		file_server
	}
}
